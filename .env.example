# Copy this file to .env and fill in your real key. .env is gitignored —
# it never gets committed. This is the ONE key the server holds; end users
# of the deployed app do not need a key of their own (see README).

ANTHROPIC_API_KEY=sk-ant-...

# Model the backend calls. Defaults to Opus if unset.
CLAUDE_MODEL=claude-opus-4-8

# Shared access code required to use the app. Pick a long random string and
# share it out-of-band (text/DM) with only the people you want using this —
# it is NOT a per-user login, just a lock on the front door. Required: the
# server refuses all chat requests if this is unset.
APP_ACCESS_CODE=choose-a-long-random-string

# Comma-separated list of origins allowed to call the API (CORS).
# For local dev with the frontend opened via a simple static server:
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Port the backend listens on.
PORT=8000

# Basic per-IP rate limiting (protects your API budget on a public deployment).
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=300
